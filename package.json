{
  "name": "kharchaaa",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "clean:metro": "powershell -Command \"Remove-Item $env:TEMP\\metro-cache,$env:TEMP\\metro-file-map* -Recurse -Force -ErrorAction SilentlyContinue; Write-Host 'Metro cache cleared'\"",
    "clean:android": "powershell -Command \"Remove-Item android\\app\\build,android\\build,android\\.gradle,android\\app\\.cxx -Recurse -Force -ErrorAction SilentlyContinue; Write-Host 'Android build cleaned'\"",
    "build:release": "npm run clean:metro && cd android && gradlew.bat assembleRelease --stacktrace",
    "build:release:clean": "npm run clean:metro && npm run clean:android && cd android && gradlew.bat assembleRelease --stacktrace",
    "build:aab": "npm run clean:metro && cd android && gradlew.bat bundleRelease --stacktrace"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react-native": "^1.0.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "immer": "^11.1.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0"
  },
  "private": true
}
